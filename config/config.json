{
  "network": {
    "csv_path": "config/networks.csv"
  },
  "cycle": {
    "receive_duration": 3.0,
    "rest_duration": 1.0,
    "max_relay_count": 6
  },
  "osc": {
    "receive_port": 8000
  },
  "mixer": {
    "host": "10.0.0.200",
    "port": 8000
  },
  "common": {
    "lang": "ja"
  },
  "stack_flow_llm": {
    "max_tokens": 128
  },
  "stack_flow_tts": {},
  "system": {},
  "audio": {
    "_desc": "=== Accumulating Ghosts パイプライン === 声のスペクトル残像が蓄積する暗い倍音テクスチャー",
    "playback_device": "dmixer",
    "tinyplay_card": 0,
    "tinyplay_device": 1,
    "sample_rate": 48000,
    "channels": 2,
    "sample_format": "s16",
    "enable_ffmpeg_convert": true,
    "enable_rumble_effect": true,
    "temp_wav_dir": "./tmp",
    "_desc_ghost": "--- ゴースト蓄積 --- 各音節がスペクトル残像を残し、後半ほど倍音クラスターが厚くなる",
    "ghost": {
      "linger_s": 2.5,
      "level": 0.42,
      "cutoff_start": 550,
      "cutoff_decay": 12,
      "resonance": 0.3
    },
    "_desc_seg": "--- セグメンテーション --- 音声をエネルギーベースで音節単位に分割",
    "segmentation": {
      "silence_threshold": 0.015,
      "min_segment_ms": 40,
      "max_segment_ms": 280
    },
    "_desc_bloom": "--- セグメントブルーム --- 各音節のフェードイン/アウト",
    "bloom": {
      "attack_ms": 25,
      "release_ms": 60
    },
    "_desc_gap": "--- ギャップフィル --- 音節間をスペクトルモーフで埋める",
    "gap_fill": {
      "level": 0.25,
      "cutoff": 500
    },
    "_desc_reverb": "--- Schroederリバーブ --- アルゴリズムリバーブ（aecho不使用）",
    "reverb": {
      "room_size": 0.82,
      "damping": 0.45,
      "wet": 0.22,
      "predelay_ms": 15
    },
    "_desc_mastering": "--- マスタリング --- テープサチュレーション+マルチバンドEQ+コンプレッサー",
    "mastering": {
      "saturation_drive": 0.2,
      "low_boost_db": 2.5,
      "mid_cut_db": -1.5,
      "air_boost_db": 1.0,
      "comp_threshold_db": -16,
      "comp_ratio": 2.5
    },
    "_desc_stereo": "--- ステレオ --- Haas式デコリレーション",
    "stereo_width": 0.25,
    "_desc_global": "--- グローバルブルーム --- 全体のフェードイン/アウト",
    "global_bloom": {
      "attack_s": 0.5,
      "release_s": 0.4
    },
    "_desc_voice": "--- 声レベル --- 声の音量バランス",
    "voice_level": 0.58,
    "_desc_mode": "--- エフェクトモード --- ghost=蓄積ゴースト rumble=旧ランブル off=加工なし",
    "effect_mode": "ghost",
    "_desc_text": "--- テキスト変換 --- ひらがな化＋母音伸ばし。elongation_mode: dash/vowel/mixed/off",
    "text_transform": {
      "enabled": true,
      "to_hiragana": true,
      "elongation_mode": "mixed",
      "elongation_probability": 0.5,
      "elongation_length": {
        "min": 2,
        "max": 5
      }
    }
  },
  "led_control": {
    "enabled": true,
    "targets": [
      {
        "host": "127.0.0.1",
        "port": 9000
      }
    ],
    "fade_steps": 40,
    "fade_up_duration": 2.0,
    "fade_down_duration": 2.0,
    "waiting_min_brightness": 0.05,
    "waiting_max_brightness": 0.25,
    "pca9685": {
      "addr": 64,
      "channel": 0,
      "bus": null,
      "freq": 1000.0,
      "gamma": 1.0,
      "max_brightness": 1.0,
      "fade": 0.0,
      "rate": 100.0,
      "reconnect_interval": 2.0
    }
  },
  "llm_settings": {
    "ja": {
      "model": "TinySwallow-1.5B",
      "system_prompt": "植物の翻訳者。森林の詩を短い単語で紡ぐ。",
      "instruction_prompt": "続き: "
    },
    "en": {
      "model": "TinySwallow-1.5B",
      "system_prompt": "Translator of plants. String short words about forests.",
      "instruction_prompt": "continue: "
    },
    "fr": {
      "model": "TinySwallow-1.5B",
