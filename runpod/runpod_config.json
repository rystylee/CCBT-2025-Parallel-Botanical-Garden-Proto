{
  "_desc": "=== RunPod リモート処理 共通設定 ===",

  "ssh": {
      "user": "root",
      "host": "69.30.85.9",
      "port": 22039,
      "key": "~/.ssh/id_ed25519",
      "connect_timeout": 10,
      "options": [
          "-o", "StrictHostKeyChecking=accept-new",
          "-o", "ServerAliveInterval=30",
          "-o", "ServerAliveCountMax=3"
      ]
  },
  "runpod": {
    "_desc": "RunPod上のパス構成",
    "workspace": "/workspace",
    "repo_dir": "/workspace/dev/CCBT-2025-Parallel-Botanical-Garden-Proto",
    "seed_vc_dir": "/workspace/dev/seed-vc",
    "melo_dir": "/workspace/dev/MeloTTS",
    "melo_bin": "/workspace/dev/MeloTTS/.venv/bin/melo",
    "osc_json_dir": "/workspace/dev/seed-vc/osc",
    "tts_out_dir": "/workspace/dev/seed-vc/tts_out",
    "vc_out_dir": "/workspace/dev/seed-vc/bi_outputs",
    "audio_dir": "/workspace/dev/CCBT-2025-Parallel-Botanical-Garden-Proto/audio",
    "target_audio": "/workspace/dev/CCBT-2025-Parallel-Botanical-Garden-Proto/audio/sample_BeforeMeaningComes_A.m4a",
    "worker_script": "/workspace/dev/CCBT-2025-Parallel-Botanical-Garden-Proto/runpod/runpod_a_make_voice.py"
  },

  "ubuntu_sender": {
    "_desc": "Ubuntu(10.0.0.200)側 OSC受信→RunPod送信",
    "osc_listen_ip": "0.0.0.0",
    "osc_listen_port": 8000,
    "osc_address": "/mixer"
  },

  "ubuntu_puller": {
    "_desc": "Ubuntu側 RunPod→ローカルへの結果取得",
    "local_output_dir": "./runpod_outputs",
    "poll_interval_sec": 3.0,
    "stable_sec": 2.0,
    "audio_extensions": [".wav"],
    "remove_remote_after_pull": true,
    "play_on_pull": false
  }
}
